{
  "name": "merchant-analytics-fraud-platform",
  "version": "1.0.0",
  "description": "A comprehensive merchant analytics and fraud detection platform",
  "private": true,
  "workspaces": [
    "services/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix services/api-gateway\"",
    "build": "tsc",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "concurrently": "^8.2.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "pg": "^8.21.0",
    "uuid": "^14.0.0",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  }
}
